{
  "expo": {
    "name": "Barricade",
    "slug": "barricade",
    "version": "1.0.0",
    "scheme": "barricade",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.priyanshu.barricade"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 14,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F2"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.priyanshu.barricade",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.587302474132-dhj0k33kpgpel7hgi34tn98ttoefjs6r"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native",
        {
          "organization": "smash-tr",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bee781e0-a8ea-4954-abbc-94439f719bf1"
      }
    },
    "owner": "priyanshu0706"
  }
}
