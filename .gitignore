# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# EAS local credentials (contains keystore passwords — never commit)
credentials.json

# Firebase service-account private keys — SECRET, never commit (belongs in Railway env only)
*-firebase-adminsdk-*.json
*serviceAccount*.json

# server build
server/dist/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Claude Code — ignore local settings/memory but track rule files
.claude/
!.claude/rules/
!.claude/rules/*.md

# PEPK / keystore tooling leftovers (do not commit)
pepk.jar
bcprov.jar
bcprov-old.jar
Launcher.class
Launcher.java
ListProviders.class
ListProviders.java
TestCipher.class
TestCipher.java
output.zip
